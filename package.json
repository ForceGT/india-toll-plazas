{
  "name": "india-toll-plazas",
  "version": "1.0.0",
  "description": "Comprehensive open-source dataset of Indian toll plazas with real-time rates, locations, and detailed information for NHAI highways and state highways",
  "main": "fetch-and-process.sh",
  "scripts": {
    "fetch": "node scripts/fetchNhaiTollplazas.js",
    "fetch-details": "node scripts/fetchNhaiDetailsParallel.js",
    "get-vehicle-types": "node scripts/getVehicleTypes.js",
    "get-states": "node scripts/getStates.js",
    "process-nhai": "node scripts/processNhai.js",
    "process-state": "node scripts/processStateHighways.js",
    "merge": "node scripts/merge.js",
    "update": "./fetch-and-process.sh"
  },
  "keywords": [
    "toll",
    "toll-plaza",
    "toll-rates",
    "india",
    "nhai",
    "national-highways",
    "state-highways",
    "highway-toll",
    "toll-booth",
    "toll-collection",
    "vehicle-rates",
    "highways",
    "dataset",
    "open-data",
    "open-source",
    "json",
    "geospatial",
    "transportation",
    "india-roads",
    "toll-information"
  ],
  "author": "",
  "license": "Government Open Data License",
  "dependencies": {
    "http-proxy-agent": "^7.0.0",
    "https-proxy-agent": "^7.0.0",
    "pdfjs-dist": "^5.7.284",
    "puppeteer": "^24.15.0"
  }
}
